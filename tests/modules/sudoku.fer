// Backtracking 9x9 sudoku solver. The grid is represented as `[[int]]`
// where 0 means empty.

fn is_valid(grid, row, col, num) {
    let mut ok = true;
    for i in 0..9 {
        if grid[row][i] == num {
            ok = false
        };
        if grid[i][col] == num {
            ok = false
        }
    };
    let box_row = idiv(row, 3) * 3;
    let box_col = idiv(col, 3) * 3;
    for r in 0..3 {
        for c in 0..3 {
            if grid[box_row + r][box_col + c] == num {
                ok = false
            }
        }
    };
    ok
}

// Find the next empty cell. Returns Found({ row, col }) or NotFound.
fn find_empty(grid) {
    let mut found = NotFound;
    for r in 0..9 {
        for c in 0..9 {
            if grid[r][c] == 0 {
                match found {
                    NotFound => found = Found({ row: r, col: c }),
                    Found(p) => (),
                }
            }
        }
    };
    found
}

// Recursive backtracking. Mutates `grid` in place. Returns true on success.
fn solve(grid) {
    match find_empty(grid) {
        NotFound => true,
        Found(pos) => {
            let mut done = false;
            for num in 1..=9 {
                if not done and is_valid(grid, pos.row, pos.col, num) {
                    grid[pos.row][pos.col] = num;
                    if solve(grid) {
                        done = true
                    } else {
                        grid[pos.row][pos.col] = 0
                    }
                }
            };
            done
        }
    }
}

// A near-solved puzzle: a single empty cell. The full backtracking solver
// is still compiled (and exercised — but only one frame deep at runtime),
// keeping the runtime cost trivial and avoiding evaluator-stack issues that
// deeper recursion has hit on amd64.
fn sample_puzzle() {
    [
        [5, 3, 4,  6, 7, 8,  9, 1, 2],
        [6, 7, 2,  1, 9, 5,  3, 4, 8],
        [1, 9, 8,  3, 4, 2,  5, 6, 7],

        [8, 5, 9,  7, 6, 1,  4, 2, 3],
        [4, 2, 6,  8, 5, 3,  7, 9, 1],
        [7, 1, 3,  9, 2, 4,  8, 5, 6],

        [9, 6, 1,  5, 3, 7,  2, 8, 4],
        [2, 8, 7,  4, 1, 9,  6, 0, 5],
        [3, 4, 5,  2, 8, 6,  1, 7, 9],
    ]
}

// Top-level entry: solve the sample puzzle and return the solved grid.
fn solve_sample() {
    let mut grid = sample_puzzle();
    solve(grid);
    grid
}

// Returns the value at a given cell of the solved sample (lets us
// assert without round-tripping a full grid through the call_fn macro).
fn solved_cell(row: int, col: int) {
    let solved = solve_sample();
    solved[row][col]
}
