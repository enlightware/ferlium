fn rle_encode(s) {
    if len(s) == 0 {
        ""
    } else {
        let mut result = "";
        let mut current = "";
        let mut count = 0;
        for c in s {
            if c == current {
                count = count + 1
            } else {
                if count > 0 {
                    result = f"{result}{current}{count}"
                };
                current = c;
                count = 1
            }
        };
        f"{result}{current}{count}"
    }
}

fn rle_encode_string(s: string) {
    rle_encode(s)
}