/// A dynamic data value used by serialization codecs.
pub enum DataValue {
	Null,
	Unit,
	Bool(bool),
	Int(int),
	Float(float),
	String(string),
	Array([DataValue]),
	Tuple([DataValue]),
	Record([(string, DataValue)]),
	Set([DataValue]),
	Map([(DataValue, DataValue)]),
	Variant { name: string, payload: DataValue },
}
